#!/bin/bash

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

CONF_FILE="/etc/modprobe.d/blacklist-kvm.conf"

function check_installed() {
    echo -e "${GREEN}Installed Hypervisors on this device:${NC}"
    local found=0
    
    if command -v virsh &> /dev/null || command -v qemu-system-x86_64 &> /dev/null || command -v virt-manager &> /dev/null; then
        echo -e "  [✔] ${BLUE}KVM / QEMU${NC} is installed."
        found=1
    fi
    
    if command -v VBoxManage &> /dev/null || command -v virtualbox &> /dev/null; then
        echo -e "  [✔] ${BLUE}VirtualBox${NC} is installed."
        found=1
    fi
    
    if command -v vmware &> /dev/null || command -v vmplayer &> /dev/null || command -v vmrun &> /dev/null; then
        echo -e "  [✔] ${BLUE}VMware${NC} is installed."
        found=1
    fi
    
    if command -v xl &> /dev/null || command -v xe &> /dev/null; then
        echo -e "  [✔] ${BLUE}Xen${NC} is installed."
        found=1
    fi
    
    if command -v pveversion &> /dev/null; then
        echo -e "  [✔] ${BLUE}Proxmox VE${NC} is installed."
        found=1
    fi
    
    if command -v multipass &> /dev/null; then
        echo -e "  [✔] ${BLUE}Multipass${NC} is installed."
        found=1
    fi
    
    if [ $found -eq 0 ]; then
        echo -e "  [-] No supported hypervisors detected in PATH."
    fi
    echo ""
}

function usage() {
    echo -e "${BLUE}Usage:${NC} vm-manager use [kvm|vbox|vmware|xen|proxmox|multipass]"
    echo -e "       vm-manager sign"
    echo -e "Try 'vm-manager --help' for more information."
    echo ""
    check_installed
    exit 1
}

function show_help() {
    echo -e "${BLUE}VM-Manager - Virtualization Switcher${NC}"
    echo -e "Usage: vm-manager use [hypervisor]"
    echo -e "       vm-manager sign"
    echo -e "       vm-manager --help | -h"
    echo -e ""
    check_installed
    echo -e "${GREEN}Supported Hypervisors & Details:${NC}"
    echo -e "  ${BLUE}kvm${NC}       - KVM with Libvirt/Virt-Manager: Considered the 'holy trinity' for Linux virtualization."
    echo -e "               A type-1 hypervisor built into the Linux kernel. Managed via Libvirt/Virt-Manager"
    echo -e "               or virsh. Ideal for server environments and running multiple headless guests."
    echo -e "  ${BLUE}vbox${NC}      - VirtualBox: A popular type-2 hypervisor that is free and open-source. User-friendly"
    echo -e "               for desktop users and supports cloning virtual disks using differencing layers."
    echo -e "  ${BLUE}vmware${NC}    - VMware: VMware Workstation Pro/Player. For enterprise bare-metal virtualization,"
    echo -e "               VMware ESXi is a dedicated hypervisor option."
    echo -e "  ${BLUE}xen${NC}       - Xen: An open-source type-1 hypervisor specifically designed for hosting multiple"
    echo -e "               VMs efficiently. Supports user-specific access controls (XenCenter or CLI)."
    echo -e "  ${BLUE}proxmox${NC}   - Proxmox VE: A free, open-source server virtualization management platform based"
    echo -e "               on Debian Linux. Uses KVM/LXC under the hood."
    echo -e "  ${BLUE}multipass${NC} - Multipass: A tool by Canonical for launching Ubuntu VMs quickly using QEMU/KVM."
    echo -e "               Designed for developers simulating cloud deployments locally."
    exit 0
}

if [[ "$1" == "-h" ]] || [[ "$1" == "--help" ]]; then
    show_help
fi

# Check for root privileges
if [[ $EUID -ne 0 ]]; then
   echo -e "${RED}[!] Error: This script must be run with sudo.${NC}"
   exit 1
fi

function sign_modules() {
    echo -e "${BLUE}[+] Signing kernel modules for Secure Boot...${NC}"
    
    if command -v mokutil &> /dev/null; then
        if ! mokutil --sb-state | grep -q "SecureBoot enabled"; then
            echo -e "${GREEN}[✔] Secure Boot is disabled. No need to sign modules.${NC}"
            exit 0
        fi
    fi

    local MOK_DIR="/root/.mok"
    mkdir -p "$MOK_DIR"
    
    if [ ! -f "$MOK_DIR/MOK.priv" ] || [ ! -f "$MOK_DIR/MOK.der" ]; then
        echo -e "${BLUE}[+] Generating Machine Owner Key (MOK)...${NC}"
        openssl req -new -x509 -newkey rsa:2048 -keyout "$MOK_DIR/MOK.priv" -outform DER -out "$MOK_DIR/MOK.der" -nodes -days 36500 -subj "/CN=VM-Manager/" 2>/dev/null
        echo -e "${GREEN}[✔] Key generated at $MOK_DIR${NC}"
    fi

    local KERNEL_VER=$(uname -r)
    local SIGN_TOOL="/usr/src/linux-headers-$KERNEL_VER/scripts/sign-file"

    if [ ! -f "$SIGN_TOOL" ]; then
        echo -e "${RED}[!] Error: Cannot find sign-file tool. Please install linux-headers: apt install linux-headers-$KERNEL_VER${NC}"
        exit 1
    fi

    if command -v vmware &> /dev/null || command -v vmplayer &> /dev/null; then
        for mod in vmmon vmnet; do
            local mod_path=$(modinfo -n $mod 2>/dev/null)
            if [ -n "$mod_path" ]; then
                echo -e "  -> Signing VMware module: $mod"
                "$SIGN_TOOL" sha256 "$MOK_DIR/MOK.priv" "$MOK_DIR/MOK.der" "$mod_path"
            fi
        done
    fi

    if command -v VBoxManage &> /dev/null || command -v virtualbox &> /dev/null; then
        for mod in vboxdrv vboxnetadp vboxnetflt; do
            local mod_path=$(modinfo -n $mod 2>/dev/null)
            if [ -n "$mod_path" ]; then
                echo -e "  -> Signing VirtualBox module: $mod"
                "$SIGN_TOOL" sha256 "$MOK_DIR/MOK.priv" "$MOK_DIR/MOK.der" "$mod_path"
            fi
        done
    fi

    echo -e "${BLUE}[+] Enrolling MOK to firmware...${NC}"
    echo -e "${GREEN}IMPORTANT: You will be prompted to create a password for MOK enrollment.${NC}"
    echo -e "${GREEN}After this script finishes, you MUST reboot your system.${NC}"
    echo -e "${GREEN}Upon reboot, a blue 'MOK management' screen will appear. Select 'Enroll MOK', 'Continue', 'Yes', and enter the password you just created.${NC}"
    
    mokutil --import "$MOK_DIR/MOK.der"
    
    echo -e "${GREEN}[✔] Signing complete! Please REBOOT your system to enroll the key.${NC}"
    exit 0
}

if [ "$1" == "sign" ]; then
    sign_modules
fi

if [ "$1" != "use" ]; then
    usage
fi

case "$2" in
    kvm|proxmox|multipass)
        if [ "$2" == "kvm" ]; then
            MODE_NAME="KVM"
        elif [ "$2" == "proxmox" ]; then
            MODE_NAME="Proxmox (KVM)"
        else
            MODE_NAME="Multipass (KVM)"
        fi
        
        echo -e "${GREEN}[+] Switching to $MODE_NAME mode...${NC}"
        
        # Clear the blacklist file to allow KVM modules
        : > "$CONF_FILE"
        
        # Attempt to unload VirtualBox and VMware modules
        modprobe -r vboxnetadp vboxnetflt vboxdrv 2>/dev/null
        systemctl stop vmware &>/dev/null || /etc/init.d/vmware stop &>/dev/null
        modprobe -r vmmon vmnet 2>/dev/null
        
        # Load KVM modules based on CPU architecture
        modprobe kvm_intel 2>/dev/null || modprobe kvm_amd 2>/dev/null
        
        echo -e "${GREEN}[✔] $MODE_NAME is now enabled. Virtualization conflict resolved.${NC}"
        ;;
    vbox)
        echo -e "${RED}[+] Switching to VirtualBox mode...${NC}"
        
        # Write blacklist entries to prevent KVM from loading
        echo -e "blacklist kvm\nblacklist kvm_intel\nblacklist kvm_amd" > "$CONF_FILE"
        
        # Unload KVM and VMware modules
        modprobe -r kvm_intel kvm_amd kvm 2>/dev/null
        systemctl stop vmware &>/dev/null || /etc/init.d/vmware stop &>/dev/null
        modprobe -r vmmon vmnet 2>/dev/null
        
        # Load VirtualBox driver
        modprobe vboxdrv 2>/dev/null
        
        echo -e "${RED}[✔] VirtualBox is now enabled. KVM has been blacklisted.${NC}"
        ;;
    vmware)
        echo -e "${BLUE}[+] Switching to VMware mode...${NC}"
        
        # Write blacklist entries to prevent KVM from loading
        echo -e "blacklist kvm\nblacklist kvm_intel\nblacklist kvm_amd" > "$CONF_FILE"
        
        # Unload KVM and VirtualBox modules
        modprobe -r kvm_intel kvm_amd kvm 2>/dev/null
        modprobe -r vboxnetadp vboxnetflt vboxdrv 2>/dev/null
        
        # Start VMware services and load modules
        systemctl restart vmware &>/dev/null || /etc/init.d/vmware restart &>/dev/null
        modprobe vmmon 2>/dev/null
        modprobe vmnet 2>/dev/null
        
        echo -e "${BLUE}[✔] VMware is now enabled. KVM has been blacklisted.${NC}"
        ;;
    xen)
        echo -e "${BLUE}[+] Switching to Xen mode...${NC}"
        
        # Write blacklist entries to prevent KVM from loading
        echo -e "blacklist kvm\nblacklist kvm_intel\nblacklist kvm_amd" > "$CONF_FILE"
        
        # Unload KVM, VirtualBox, and VMware modules
        modprobe -r kvm_intel kvm_amd kvm 2>/dev/null
        modprobe -r vboxnetadp vboxnetflt vboxdrv 2>/dev/null
        systemctl stop vmware &>/dev/null || /etc/init.d/vmware stop &>/dev/null
        modprobe -r vmmon vmnet 2>/dev/null
        
        echo -e "${BLUE}[✔] Virtualization modules unloaded. Note: Xen typically requires booting into a Xen-enabled kernel.${NC}"
        ;;
    *)
        usage
        ;;
esac
